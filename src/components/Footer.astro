---
import { ArrowRight, ExternalLink } from "@lucide/astro";
import { products, site } from "@/data/site";
---

<footer class="site-footer">
  <div class="footer-split">
    <!-- LEFT COLUMN: Brand + Nav + Copyright -->
    <div class="footer-left">
      <a href="/" class="footer-logo" aria-label="Run Flat Machine home">
        <img src="/assets/logo.png" alt="Run Flat Machine" width="160" height="69" />
      </a>

      <nav class="footer-nav" aria-label="Footer navigation">
        <a href="/">Home</a>
        <a href="/products/">Products</a>
        <a href="/frequenty-asked-questions/">FAQ</a>
        <a href="/blog/">Blog</a>
        <a href="/contact-us/">Contact Us</a>
      </nav>

      <p class="footer-copyright">
        &copy; Copyright - {new Date().getFullYear()} | All rights reserved.
      </p>
    </div>

    <!-- RIGHT COLUMN: Description + CTA -->
    <div class="footer-right">
      <p class="footer-desc">
        Explore GM Defensive's innovative Run-Flat Changer Machine for military and armored vehicles. 
        Experience enhanced efficiency, safety, and quality assurance.
      </p>

      <a class="footer-cta-btn" href={site.external} target="_blank" rel="noreferrer">
        Visit GM DEFENSIVE Today!
        <ExternalLink size={16} aria-hidden="true" />
      </a>
    </div>
  </div>
</footer>
