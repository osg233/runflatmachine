---
import { ArrowRight, CircleCheck } from "@lucide/astro";
import type { Product } from "@/data/site";

type Props = {
  product: Product;
  compact?: boolean;
};

const { product, compact = false } = Astro.props;
---

<article class:list={["product-card", compact && "compact", "reveal"]}>
  <a class="product-card-media" href={product.href} aria-label={`View ${product.shortTitle}`}>
    <span class="product-badge">{product.model}</span>
    <img src={product.image} alt={product.title} loading="eager" />
  </a>
  <div class="product-card-body">
    <p class="eyebrow">{product.eyebrow}</p>
    <h3><a href={product.href}>{product.shortTitle}</a></h3>
    <p>{product.summary}</p>
    {!compact && (
      <div class="product-spec-pills" aria-label={`${product.shortTitle} quick specs`}>
        {product.specs.slice(1, 4).map((spec) => (
          <span>
            <small>{spec.label}</small>
            {spec.value}
          </span>
        ))}
      </div>
    )}
    <ul class="check-list">
      {product.highlights.slice(0, compact ? 2 : 3).map((item) => (
        <li>
          <CircleCheck size={16} aria-hidden="true" />
          {item}
        </li>
      ))}
    </ul>
    <div class="card-actions">
      <a class="text-link" href={product.href}>
        View model
        <ArrowRight size={16} aria-hidden="true" />
      </a>
      {!compact && <a class="quote-link" href="/contact-us/">Quote</a>}
    </div>
  </div>
</article>
