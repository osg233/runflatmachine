---
import { ArrowRight } from "@lucide/astro";
import type { Post } from "@/data/site";

type Props = {
  post: Post;
};

const { post } = Astro.props;
const year = new Date(`${post.date}T00:00:00`).getFullYear();
---

<article class="post-card reveal">
  <a class="post-media" href={post.href} aria-label={`Read ${post.title}`}>
    <img src={post.image} alt="" loading="eager" />
    <span>{post.category.replaceAll("-", " ")}</span>
  </a>
  <div class="post-body">
    <div class="post-meta">
      <span>{year}</span>
    </div>
    <h3><a href={post.href}>{post.title}</a></h3>
    <p>{post.excerpt}</p>
    <a class="text-link" href={post.href}>
      Read More
      <ArrowRight size={16} aria-hidden="true" />
    </a>
  </div>
</article>
