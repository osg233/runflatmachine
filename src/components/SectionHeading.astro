---
type Props = {
  eyebrow?: string;
  title: string;
  body?: string;
  align?: "left" | "center";
};

const { eyebrow, title, body, align = "left" } = Astro.props;
---

<div class:list={["section-heading", align === "center" && "center"]}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  {body && <p>{body}</p>}
</div>
