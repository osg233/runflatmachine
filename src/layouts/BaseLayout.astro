---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import "@/styles/global.css";
import "@/styles/pdp.css";
import { site } from "@/data/site";

type Props = {
  title?: string;
  description?: string;
  canonical?: string;
  image?: string;
  noindex?: boolean;
};

const {
  title = site.name,
  description = site.description,
  canonical = Astro.url.pathname,
  image = "/assets/operation.webp",
  noindex = false,
} = Astro.props;

const pageTitle = title === site.name ? title : `${title} - ${site.name}`;
const canonicalUrl = new URL(canonical, site.domain).toString();
const imageUrl = new URL(image, site.domain).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex,follow" : "index,follow"} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/assets/logo-mark.png" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <Header />
    <main id="content">
      <slot />
    </main>
    <Footer />
    <script is:inline src="/scripts/site.js" defer></script>
  </body>
</html>
