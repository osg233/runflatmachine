---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeading from "@/components/SectionHeading.astro";
import { taxonomyPages } from "@/data/site";

export function getStaticPaths() {
  return taxonomyPages.elements.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
---

<BaseLayout
  title={`Element Category: ${item.label}`}
  description={`${item.label} element category route retained from the sitemap.`}
  noindex
>
  <section class="page-hero" style="--page-image: url('/assets/training.webp')">
    <div class="container reveal">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a><span>/</span><span>Element Category</span>
      </nav>
      <p class="eyebrow">Element category</p>
      <h1>{item.label}</h1>
      <p>This route is retained for sitemap continuity with the provided element category structure.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Sitemap continuity"
        title={`${item.label} archive`}
        body="This archive is preserved outside the main navigation because the sitemap screenshot classifies element categories separately."
      />
    </div>
  </section>
</BaseLayout>
