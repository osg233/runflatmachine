---
import { ArrowRight, BookOpen, Clock, Tag } from "@lucide/astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import { posts } from "@/data/site";

/* ── Mixed display order: interleave real photos with AI-generated ones ── */
const displayOrder = [
  "hmmwv-humvee-run-flat-tire-changer-guide",
  "military-tire-disassembly",
  "mrap-military-run-flat-tire-machine-guide",
  "military-tire-disassemble-tool",
  "stryker-apc-runflat-tire-replacement-machine",
  "comparing-gm-run-flat-machine-with-others",
  "hemtt-hutchinson-run-flat-insert-replacement-guide",
  "5-keys-of-run-flat-changer-machines-for-armored-vehicles",
  "run-flat-changer-guide-for-military-success",
];
const orderedPosts = displayOrder
  .map((slug) => posts.find((p) => p.slug === slug))
  .filter(Boolean) as typeof posts;
/* Append any posts not in the display order */
const remaining = posts.filter((p) => !displayOrder.includes(p.slug));
const allPosts = [...orderedPosts, ...remaining];

const totalArticles = allPosts.length;
---

<BaseLayout
  title="Blog"
  description="Run-flat machine resources for military tire disassembly, procurement, and armored vehicle maintenance planning."
  image="/assets/runflat-removal.webp"
>
  <section class="page-hero" style="--page-image: url('/assets/runflat-removal.webp')">
    <div class="container reveal">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">Home</a><span>/</span><span>Blog</span>
      </nav>
      <p class="eyebrow">Technical resources</p>
      <h1>Blog</h1>
      <p>
        Buyer-focused resources on military tire disassembly, run-flat machine selection, and armored vehicle maintenance
        workflows.
      </p>
    </div>
  </section>

  <!-- ── Blog Stats Strip ── -->
  <section class="blog-stats-strip">
    <div class="container">
      <div class="blog-stats-inner">
        <div class="blog-stat-item">
          <BookOpen size={16} aria-hidden="true" />
          <strong>{totalArticles}</strong>
          <span>Articles</span>
        </div>
        <div class="blog-stat-sep" aria-hidden="true"></div>
        <div class="blog-stat-item">
          <Tag size={16} aria-hidden="true" />
          <strong>7</strong>
          <span>Topics</span>
        </div>
        <div class="blog-stat-sep" aria-hidden="true"></div>
        <div class="blog-stat-item">
          <Clock size={16} aria-hidden="true" />
          <strong>2024–2026</strong>
          <span>Coverage</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Blog Grid ── -->
  <section class="section blog-listing-section">
    <div class="container">
      <div class="blog-grid-header reveal">
        <div class="blog-grid-copy">
          <p class="eyebrow">Run-flat machine insights</p>
          <h2>Expert articles on military<br/>run-flat tire systems.</h2>
        </div>
        <div class="blog-grid-actions">
          <a class="button button-primary" href="/contact-us/">
            Ask a Product Question
            <ArrowRight size={18} aria-hidden="true" />
          </a>
        </div>
      </div>
      <div class="post-grid reveal">
        {allPosts.map((post, i) => <PostCard post={post} />)}
      </div>
    </div>
  </section>
</BaseLayout>
